# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# ── Paths (relative to project root) ─────────────────────────────────────────
DATA_DIR=data/files
DB_PATH=data/db/index.db

# ── Tuning ────────────────────────────────────────────────────────────────────
MAX_RESULTS=10
DAILY_LIMIT=100
CACHE_SIZE=1000
CHUNK_SIZE=1000
MAX_FILE_SIZE_MB=50

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Misc ──────────────────────────────────────────────────────────────────────
MAINTENANCE_MODE=false
BOT_LANG=en
